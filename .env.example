# Postgres (Neon or another PostgreSQL provider)
DATABASE_URL=

# OpenAI Responses API
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6

# Shared access key for paid on-demand analysis generation.
# Dashboard users enter this same value; never expose it as a NEXT_PUBLIC_ variable.
ANALYSIS_ACCESS_TOKEN=

# GitHub webhook verification and optional private-repository job/step evidence
GITHUB_WEBHOOK_SECRET=
GITHUB_TOKEN=

# Failure notifications
SLACK_WEBHOOK_URL=
